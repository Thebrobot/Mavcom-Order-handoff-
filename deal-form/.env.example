# Paste your HighLevel Workflow "Inbound Webhook" URL (or Zapier/Make catch URL).
# Copy to `.env` and run `npm run dev` / `npm run build` again.
VITE_SUBMIT_WEBHOOK_URL=

# File upload iframe (optional): must match the embed URL from GHL if different domain/path.
# VITE_GHL_UPLOAD_FORM_EMBED_URL=https://api.leadconnectorhq.com/widget/form/YOUR_FORM_ID

# Query param name for the client email — must match the hidden field's URL/query key in the GHL form (case-sensitive). Default: email
# VITE_GHL_UPLOAD_FORM_EMAIL_PARAM=email
#
# Upload step also sets this param on the *browser page* URL (not only the iframe) so LeadConnector form_embed.js can forward it into the widget.

# Quick-link pills (Copilot, Terms). Payment URLs live in src/paymentLinks.js.
VITE_LINK_AI_KNOWLEDGE=https://chatgpt.com/g/g-69bc504e1fd481918a7085d2fa5be02e-brobot-copilot
VITE_LINK_TERMS_LOA=https://sendlink.co/documents/doc-form/69d55a0573a84b21f006c71d?locale=en-US

# ── Sales Partner Portal (Supabase) ──────────────────────────────────────────
# Create a free project at https://supabase.com, then copy these from:
#   Project Settings → API → Project URL and anon/public key
# After setting up, run deal-form/src/portal/supabase-schema.sql in the Supabase SQL Editor.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
